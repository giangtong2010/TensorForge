#include "dispatcher/register_kernel.hpp"
#include "dispatcher/_table.hpp"
#include "tensor.hpp"
#include "kernel/kernel.hpp"

{% for op in operators %}
{% for backend in op.backends %}
{% for dtype in dtypes %}

REGISTER_KERNEL(
    {{ op.name }}, 
    {{ backend|lower }},
    {{ dtype }},
    {{ op.name }}_{{ backend }}_{{ dtype }}
);

{% endfor %}
{% endfor %}
{% endfor %}
