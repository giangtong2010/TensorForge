#pragma once
#include <cstddef>

namespace dispatcher {
    enum class OP {
        {% for op in operators %}
        {{ op.name }},
        {% endfor %}
        count = {{ operators|length }}
    };
    enum class Backends {
        {% for backend in backends %}
        {{ backend }},
        {% endfor %}
        count = {{ backends|length }}
    };
    enum class Types {
        {% for dytpe in dtypes %}
        {{ dytpe }},
        {% endfor %}
        count = {{ dtypes|length }}
    };
}
